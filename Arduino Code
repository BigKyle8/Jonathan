// --- Enter searching state and reset all related vars ---
void enterSearching() {
  state            = 3;
  searchingStartTime = millis();
  sadBlinkPhase    = 0;
  sadBrightness    = 0.0;
  sadBlinkHolding  = false;
  pickSadSearchTarget();
}

// --- Move all servos to home and lock ---
void goHome() {
  servoTilt.write(HOME_TILT);
  servoPan.write(HOME_PAN);
  servoHome.write(HOME_SERVO3_SEARCH);
  currentTilt = HOME_TILT;
  currentPan  = HOME_PAN;
  forcedHome  = true;
  ring.clear();
  ring.show();
  Serial.printf("Home → tilt:%d pan:%d servo3:%d\n", HOME_TILT, HOME_PAN, HOME_SERVO3_SEARCH);
}

// --- Smooth-interpolate pan+tilt toward their targets and write to servos ---
// Called every SERVO_MS with the appropriate smoothing factor for the current state.
void interpolateServos(float smooth) {
  currentPan  += (targetPan  - currentPan)  * smooth;
  currentTilt += (targetTilt - currentTilt) * smooth;
  servoPan.write(constrain((int)currentPan,  PAN_MIN, PAN_MAX));
  servoTilt.write(constrain((int)currentTilt, TILT_MIN, TILT_MAX));
}

void setup() {
  Serial.begin(9600);
  loadPrefs();

  servoTilt.attach(PIN_TILT, 400, 2600);
  servoPan.attach(PIN_PAN,   400, 2600);
  servoHome.attach(PIN_HOME, 400, 2600);

  servoTilt.write(HOME_TILT);
  servoPan.write(HOME_PAN);
  servoHome.write(HOME_SERVO3_SEARCH);

  ring.begin();
  ring.setBrightness(BRIGHTNESS);
  ring.clear();
  ring.show();

  randomSeed(analogRead(0));

  sadColourIndex     = random(NUM_EYE_COLOURS);
  sadNextColourIndex = pickDifferentColour(sadColourIndex);

  Serial.println("Connecting to WiFi...");
  WiFi.begin(WIFI_SSID, WIFI_PASSWORD);
  while (WiFi.status() != WL_CONNECTED) {
    delay(500);
    Serial.print(".");
  }
  Serial.println("\nConnected!");
  Serial.print("ESP32 IP: ");
  Serial.println(WiFi.localIP());

  udp.begin(UDP_PORT);
  Serial.printf("Listening on UDP port %d\n", UDP_PORT);

  // Print touch baseline so you can calibrate threshold
  Serial.print("Touch baseline reading: ");
  Serial.println(touchRead(TOUCH_PIN));

  pickSadSearchTarget();
}

void loop() {
  unsigned long now = millis();

  // --- 0. Check for serial override commands ---
  while (Serial.available()) {
    char c = (char)Serial.read();
    if (c == '\n' || c == '\r') {
      if (serialBuffer.length() > 0) {
        processSerialCommand(serialBuffer);
        serialBuffer = "";
      }
    } else {
      serialBuffer += c;
    }
  }

  /* --- 1. Capacitive touch ---
   Three gestures:
     Short hold while sleeping  → wake up  (TOUCH_HOLD_MS)
     Short hold while awake     → go to sleep / home  (released after TOUCH_HOLD_MS)
     Long hold while awake      → dance mode  (DANCE_HOLD_MS, must be > TOUCH_HOLD_MS)
  */
  if (!overrideMode && now - lastTouchCheck >= TOUCH_CHECK_MS) {
    lastTouchCheck = now;

    int  touchValue = touchRead(TOUCH_PIN);
    bool isTouched  = (touchValue < TOUCH_THRESHOLD);

    // Record when the press began
    if (isTouched && !lastTouched) {
      touchStartTime = now;
      touchTriggered = false;
    }

    // Long hold while awake → start dancing
    if (isTouched && !touchTriggered && !forcedHome && !dancing && postDancePhase == 0
        && (now - touchStartTime >= (unsigned long)DANCE_HOLD_MS)) {
      touchTriggered = true;
      dancing        = true;
      danceHue       = 0.0;
      lastDanceMove  = now;
      Serial.println("Dance mode!");
    }

    // Short hold while sleeping → wake up
    if (isTouched && !touchTriggered && forcedHome
        && (now - touchStartTime >= (unsigned long)TOUCH_HOLD_MS)) {
      touchTriggered = true;
      forcedHome  = false;
      Serial.printf("Touch held %dms — waking up\n", TOUCH_HOLD_MS);
      servoTilt.write(TILT_MIN);
      currentTilt = TILT_MIN;
      targetTilt  = TILT_MIN;
      waking      = true;
      wakingStart = now;
      enterSearching();
    }

    // On finger lift — check what action to take
    if (!isTouched && lastTouched) {
      unsigned long heldFor = now - touchStartTime;

      if (dancing) {
        // Release from dance → shocked + shake
        dancing        = false;
        postDancePhase = 1;
        postDanceStart = now;
        targetPan      = HOME_PAN;
        targetTilt     = TILT_MIN;
        servoHome.write(HOME_SERVO3_TRACK);  // snap servo3 back before shocked sequence
        Serial.println("Shocked!");

      } else if (!forcedHome && !touchTriggered
                 && heldFor >= (unsigned long)TOUCH_HOLD_MS
                 && postDancePhase == 0) {
        goHome();
      }

      touchTriggered = false;
    }

    lastTouched = isTouched;
  }

  // Touch and LED updates still run while homed so the ring can go dark.
  // Everything else (UDP, state machine, servos) is skipped.
  if (forcedHome) return;
  if (overrideMode) return;

  /* --- Waking sequence ---
   After a touch wake-up the tilt servo is raised to TILT_MIN first so that
   servo3 (the extending arm) won't collide with the structure.
   WAKE_DELAY_MS gives the tilt servo time to clear before servo3 extends.
  */
  if (waking && (now - wakingStart >= (unsigned long)WAKE_DELAY_MS)) {
    servoHome.write(HOME_SERVO3_TRACK);
    waking = false;
    Serial.println("Awake!");
  }

  // --- Post-dance sequence transitions ---
  if (postDancePhase == 1 && (now - postDanceStart >= POSTDANCE_SHOCKED_MS)) {
    postDancePhase = 2;
    postDanceStart = now;
    shakeDir       = 1;
    lastShakeFlip  = now;
    Serial.println("Shaking it off...");
  }
  if (postDancePhase == 2 && (now - postDanceStart >= POSTDANCE_SHAKE_MS)) {
    postDancePhase = 0;
    servoHome.write(HOME_SERVO3_TRACK);
    enterSearching();
    Serial.println("Back to it.");
  }

  /* --- 2. Check for incoming UDP from Max ---
   Packet format: byte 0 = mode (1=face, 255=no face), bytes 1-2 = pan, tilt (mode 1 only).
   Ignored entirely while dancing or in post-dance to prevent external interruption.
  */
  int packetSize = udp.parsePacket();
  if (packetSize > 0) {
    udp.read(packetBuffer, sizeof(packetBuffer));

    if (!dancing && postDancePhase == 0) {
      int incomingMode = (unsigned char)packetBuffer[0];

      if (incomingMode == 1 && packetSize >= 3) {
        // Face detected — update target and trigger startled if not already tracking
        int pan  = (unsigned char)packetBuffer[1];
        int tilt = (unsigned char)packetBuffer[2];
        targetPan  = constrain(pan,  PAN_MIN, PAN_MAX);
        targetTilt = constrain(tilt, TILT_MIN, TILT_MAX);

        if (state == 0 || state == 3) {
          servoHome.write(HOME_SERVO3_TRACK);
          state         = 2;
          startledStart = now;
          Serial.println("Face detected! Startled...");
        }

      } else if (incomingMode == 255) {
        /* No face — transition to searching.
         If we were startled (state 2), resume searching without resetting the blink
         animation — the face was only seen briefly, so we continue where we left off.
        */
        if (state == 1 || state == 0) {
          Serial.println("No face — entering searching mode");
          servoHome.write(HOME_SERVO3_TRACK);
          enterSearching();
        } else if (state == 2) {
          state = 3;
          Serial.println("Face lost during startled — resuming search");
        }
        // state == 3: already searching, nothing to do
      }
    }
  }

  /* --- 3. State machine transitions ---
   Dance and post-dance sequences manage their own state; skip the normal
   state machine while they run (goto jumps directly to servo interpolation).
  */
  if (dancing || postDancePhase > 0) goto servoUpdate;
  switch (state) {

    case 2:   // STARTLED → TRACKING
      if (now - startledStart >= STARTLED_DURATION) {
        state      = 1;
        scanActive = false;
        nextScanAt = now + random(SCAN_INTERVAL_MIN, SCAN_INTERVAL_MAX);
        Serial.println("Tracking...");
      }
      break;

    case 3:   // SAD SEARCHING
      if (now - lastSearchMove >= searchMoveInterval) {
        pickSadSearchTarget();
      }
      break;

    case 0:
    default:
      break;
  }

  servoUpdate:
  // --- 4. Servo smooth interpolation ---
  if (now - lastServoUpdate >= SERVO_MS) {
    lastServoUpdate = now;

    if (dancing) {
      // Pick a new random target every DANCE_MOVE_MS
      if (now - lastDanceMove >= DANCE_MOVE_MS) {
        lastDanceMove = now;
        int panMid    = (PAN_MIN  + PAN_MAX)  / 2;
        int tiltMid   = (TILT_MIN + TILT_MAX) / 2;
        int panRange  = (PAN_MAX  - PAN_MIN)  / 3;
        int tiltRange = (TILT_MAX - TILT_MIN) / 3;
        targetPan  = panMid  + random(-panRange,  panRange);
        targetTilt = tiltMid + random(-tiltRange, tiltRange);
      }
      interpolateServos(0.18);
      // Home servo bobs in and out on a slow sine wave
      float bobAngle = HOME_SERVO3_TRACK + 30.0 * (0.5 + 0.5 * sin(now / 600.0));
      servoHome.write(constrain((int)bobAngle, HOME_SERVO3_TRACK, HOME_SERVO3_TRACK + 30));

    } else if (postDancePhase == 1) {
      // Shocked recoil — snap to centre
      interpolateServos(SMOOTH_STARTLED);

    } else if (postDancePhase == 2) {
      // Shake it off — oscillate pan left/right + home servo twist with it
      if (now - lastShakeFlip >= SHAKE_FLIP_MS) {
        lastShakeFlip = now;
        shakeDir      = -shakeDir;
        targetPan     = HOME_PAN + shakeDir * SHAKE_AMOUNT;
        servoHome.write(HOME_SERVO3_TRACK + (shakeDir > 0 ? 35 : 0));
      }
      currentPan  += (targetPan  - currentPan)  * 0.5;
      currentTilt += (targetTilt - currentTilt) * 0.15;
      servoPan.write(constrain((int)currentPan,  PAN_MIN, PAN_MAX));
      servoTilt.write(constrain((int)currentTilt, TILT_MIN, TILT_MAX));

    } else if (state == 2) {
      interpolateServos(SMOOTH_STARTLED);   // fast snap while startled
    } else if (state == 1) {
      interpolateServos(SMOOTH_TRACK);      // smooth follow while tracking
    } else if (state == 3) {
      interpolateServos(SMOOTH_SEARCH);     // very slow drift while searching
    }
  }

  // --- 5. NeoPixel update ---
  if (now - lastLedUpdate >= LED_MS) {
    lastLedUpdate = now;

    // While searching, dim the ring gradually from 75% → 25% of BRIGHTNESS over
    // SEARCH_DIM_SECS seconds — simulating tiredness the longer no face is found.
    if (state == 3 && !dancing && postDancePhase == 0) {
      float elapsed     = constrain((float)(millis() - searchingStartTime) / (SEARCH_DIM_SECS * 1000.0), 0.0, 1.0);
      float brightScale = 0.75f - 0.50f * elapsed;   // 75% → 25%
      ring.setBrightness((int)(BRIGHTNESS * brightScale));
    } else {
      ring.setBrightness(BRIGHTNESS);
    }

    if (dancing) {
      updateDance();
    } else if (postDancePhase == 1) {
      updateStartled(postDanceStart);
    } else if (postDancePhase == 2) {
      updateShakeOff(now);
    } else if (state == 2) {
      updateStartled(startledStart);
    } else if (state == 1) {
      updateTracking();
    } else if (state == 3) {
      updateSadSearching();
    } else {
      // state 0 / homing / sleeping — ring stays dark
      ring.clear();
    }

    ring.show();
  }
}

/* --- Process serial override commands ---
 Commands (type in Serial Monitor, set to Newline):

  OVERRIDE:
   x          → override ON  (pause state machine)
   o          → override OFF (resume normal operation)

  SERVOS (work in override mode):
   t<angle>   → tilt servo   e.g. t90
   p<angle>   → pan servo    e.g. p45
   h<angle>   → home servo   e.g. h160
   home       → move all servos to defined home positions
   c          → centre all servos (90°)
   a          → all servos → 0°
   b          → all servos → 180°

  LED (work in override mode):
   led=r,g,b  → set all pixels to solid colour  e.g. led=0,0,255
   led=off    → turn LEDs off

  STATE TEST (forces state, useful to audition LED effects):
   state=0    → homing
   state=1    → tracking
   state=2    → startled
   state=3    → searching

  TUNING (key=value, work any time):
   smooth_track=0.12      pan/tilt follow speed while tracking
   smooth_search=0.02     pan/tilt follow speed while searching
   smooth_startled=0.4    snap speed on new face detection
   brightness=150         NeoPixel master brightness (0-255)
   track_hue=0.72         tracking colour hue (0.0-1.0)
   pulse_speed=0.006      tracking pulse animation speed
   pulse_min=0.15         tracking pulse minimum brightness
   pulse_max=0.55         tracking pulse maximum brightness
   fade_speed=0.004       searching colour fade speed
   fade_max=0.5           searching maximum brightness
   startled_ms=600        startled flash duration in ms
   pan_min=30             pan servo minimum angle
   pan_max=150            pan servo maximum angle
   tilt_min=45            tilt servo minimum angle
   tilt_max=135           tilt servo maximum angle
   touch_threshold=40     raw reading below this = touched (lower = less sensitive)
   touch_hold_ms=300      how long you must hold before it fires

  INFO:
   status     → current state, positions, override flag
   params     → print all current tunable values

  PERSISTENCE:
   save       → write all current values to flash (survives reboot)
   defaults   → wipe saved values and restore hardcoded defaults
*/

void processSerialCommand(String cmd) {
  cmd.trim();
  if (cmd.length() == 0) return;

  // --- Persistence ---
  if (cmd == "save" || cmd == "SAVE") {
    savePrefs();
    return;
  }
  if (cmd == "defaults" || cmd == "DEFAULTS") {
    prefs.begin("eye", false);
    prefs.clear();
    prefs.end();
    // Restore hardcoded defaults
    SMOOTH_TRACK       = 0.12;  SMOOTH_SEARCH    = 0.02;  SMOOTH_STARTLED  = 0.4;
    BRIGHTNESS         = 150;   TRACK_HUE        = 0.72;  TRACK_PULSE_SPEED = 0.006;
    TRACK_PULSE_MIN    = 0.15;  TRACK_PULSE_MAX  = 0.55;  SAD_FADE_SPEED   = 0.004;
    SAD_BRIGHTNESS_MAX = 0.5;   STARTLED_DURATION = 600;
    PAN_MIN  = 30;  PAN_MAX  = 150;  TILT_MIN = 45;  TILT_MAX = 135;
    TOUCH_THRESHOLD = 800;  TOUCH_HOLD_MS = 150;  DANCE_HOLD_MS = 800;
    DANCE_MOVE_MS = 350;  POSTDANCE_SHOCKED_MS = 500;  POSTDANCE_SHAKE_MS = 900;
    SHAKE_FLIP_MS = 75;   SHAKE_AMOUNT = 35;
    HOME_TILT = 173;  HOME_PAN = 90;  HOME_SERVO3_SEARCH = 160;  HOME_SERVO3_TRACK = 0;
    WAKE_DELAY_MS = 100;
    SEARCH_MOVE_MIN = 2000;  SEARCH_MOVE_MAX = 5000;
    SAD_TILT_MIN = 90;  SAD_TILT_MAX = 135;  SAD_PAN_MIN = 40;  SAD_PAN_MAX = 140;
    BLINK_STEP_MS = 35;  BLINK_HOLD_MS = 2000;  SEARCH_DIM_SECS = 30;
    SCAN_STEP_MS = 60;   SCAN_INTERVAL_MIN = 5000;  SCAN_INTERVAL_MAX = 15000;
    ring.setBrightness(BRIGHTNESS);
    Serial.println("Defaults restored. Type 'save' to make them permanent.");
    return;
  }

  // --- Override toggle ---
  if (cmd == "x" || cmd == "X") {
    overrideMode = true;
    Serial.println("Override ON — state machine paused");
    return;
  }
  if (cmd == "o" || cmd == "O") {
    overrideMode = false;
    Serial.println("Override OFF — resuming normal operation");
    return;
  }

  // --- Status ---
  if (cmd == "status" || cmd == "STATUS") {
    Serial.print("State: ");     Serial.print(state);
    Serial.print("  ForcedHome: "); Serial.print(forcedHome);
    Serial.print("  Override: ");   Serial.print(overrideMode);
    Serial.print("  Pan: ");    Serial.print((int)currentPan);
    Serial.print("  Tilt: ");   Serial.println((int)currentTilt);
    return;
  }

  // --- Print all tunable params ---
  if (cmd == "params" || cmd == "PARAMS") {
    Serial.println("--- Tunable Parameters ---");
    Serial.print("smooth_track=");    Serial.println(SMOOTH_TRACK, 4);
    Serial.print("smooth_search=");   Serial.println(SMOOTH_SEARCH, 4);
    Serial.print("smooth_startled="); Serial.println(SMOOTH_STARTLED, 4);
    Serial.print("brightness=");      Serial.println(BRIGHTNESS);
    Serial.print("track_hue=");       Serial.println(TRACK_HUE, 4);
    Serial.print("pulse_speed=");     Serial.println(TRACK_PULSE_SPEED, 4);
    Serial.print("pulse_min=");       Serial.println(TRACK_PULSE_MIN, 4);
    Serial.print("pulse_max=");       Serial.println(TRACK_PULSE_MAX, 4);
    Serial.print("fade_speed=");      Serial.println(SAD_FADE_SPEED, 4);
    Serial.print("fade_max=");        Serial.println(SAD_BRIGHTNESS_MAX, 4);
    Serial.print("startled_ms=");     Serial.println(STARTLED_DURATION);
    Serial.print("pan_min=");         Serial.println(PAN_MIN);
    Serial.print("pan_max=");         Serial.println(PAN_MAX);
    Serial.print("tilt_min=");        Serial.println(TILT_MIN);
    Serial.print("tilt_max=");        Serial.println(TILT_MAX);
    Serial.print("touch_threshold="); Serial.println(TOUCH_THRESHOLD);
    Serial.print("touch_hold_ms=");   Serial.println(TOUCH_HOLD_MS);
    Serial.print("dance_hold_ms=");   Serial.println(DANCE_HOLD_MS);
    Serial.print("touch_baseline=");  Serial.println(touchRead(TOUCH_PIN));
    Serial.println("--- Dance ---");
    Serial.print("dance_move_ms=");   Serial.println(DANCE_MOVE_MS);
    Serial.print("shocked_ms=");      Serial.println(POSTDANCE_SHOCKED_MS);
    Serial.print("shake_ms=");        Serial.println(POSTDANCE_SHAKE_MS);
