      Serial.print("pulse_min = "); Serial.println(TRACK_PULSE_MIN, 4);
    } else if (key == "pulse_max") {
      TRACK_PULSE_MAX = constrain(fval, 0.0, 1.0);
      Serial.print("pulse_max = "); Serial.println(TRACK_PULSE_MAX, 4);
    } else if (key == "fade_speed") {
      SAD_FADE_SPEED = constrain(fval, 0.0001, 0.1);
      Serial.print("fade_speed = "); Serial.println(SAD_FADE_SPEED, 4);
    } else if (key == "fade_max") {
      SAD_BRIGHTNESS_MAX = constrain(fval, 0.0, 1.0);
      Serial.print("fade_max = "); Serial.println(SAD_BRIGHTNESS_MAX, 4);
    } else if (key == "startled_ms") {
      STARTLED_DURATION = constrain(ival, 50, 5000);
      Serial.print("startled_ms = "); Serial.println(STARTLED_DURATION);
    } else if (key == "pan_min") {
