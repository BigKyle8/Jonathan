    } else if (key == "blink_step_ms") {
      BLINK_STEP_MS = constrain(ival, 5, 500);
      Serial.print("blink_step_ms = "); Serial.println(BLINK_STEP_MS);
    } else if (key == "blink_hold_ms") {
      BLINK_HOLD_MS = constrain(ival, 100, 10000);
      Serial.print("blink_hold_ms = "); Serial.println(BLINK_HOLD_MS);
    } else if (key == "search_dim_secs") {
      SEARCH_DIM_SECS = constrain(ival, 1, 300);
      Serial.print("search_dim_secs = "); Serial.println(SEARCH_DIM_SECS);
    } else if (key == "scan_step_ms") {
      SCAN_STEP_MS = constrain(ival, 5, 500);
      Serial.print("scan_step_ms = "); Serial.println(SCAN_STEP_MS);
    } else if (key == "scan_min_ms") {
      SCAN_INTERVAL_MIN = constrain(ival, 500, 60000);
      Serial.print("scan_min_ms = "); Serial.println(SCAN_INTERVAL_MIN);
    } else if (key == "scan_max_ms") {
      SCAN_INTERVAL_MAX = constrain(ival, 500, 60000);
      Serial.print("scan_max_ms = "); Serial.println(SCAN_INTERVAL_MAX);
    } else {
      Serial.print("Unknown param: "); Serial.println(key);
      Serial.println("Type 'params' to see all tunable values");
    }
    return;
  }

  // --- Single servo commands: t90, p45, h150 ---
  char type  = cmd.charAt(0);
  int  angle = constrain(cmd.substring(1).toInt(), 0, 180);

  switch (type) {
    case 't': case 'T':
      servoTilt.write(angle);
      currentTilt = angle;
      Serial.print("Tilt → "); Serial.print(angle); Serial.println("°");
      break;
    case 'p': case 'P':
      servoPan.write(angle);
      currentPan = angle;
      Serial.print("Pan  → "); Serial.print(angle); Serial.println("°");
      break;
    case 'h': case 'H':
      servoHome.write(angle);
      Serial.print("Home → "); Serial.print(angle); Serial.println("°");
      break;
    default:
      Serial.println("Unknown command. Type 'params' for tuning or 'status' for info.");
      break;
  }
}

// --- NeoPixel: dance — spinning rainbow ---
void updateDance() {
  danceHue += 0.008;
  if (danceHue >= 1.0) danceHue -= 1.0;
  for (int i = 0; i < NEO_COUNT; i++) {
    float hue = fmod(danceHue + (float)i / NEO_COUNT, 1.0);
    ring.setPixelColor(i, hsvToRgb(hue, 1.0, 0.9));
  }
}

// --- NeoPixel: shake-off — fade from white to sad searching colour ---
void updateShakeOff(unsigned long now) {
  float t = (float)(now - postDanceStart) / (float)POSTDANCE_SHAKE_MS;
  t = constrain(t, 0.0, 1.0);
  uint8_t cr = EYE_COLOURS[sadColourIndex][0];
  uint8_t cg = EYE_COLOURS[sadColourIndex][1];
  uint8_t cb = EYE_COLOURS[sadColourIndex][2];
  uint8_t r = (uint8_t)(255 + (cr - 255) * t);
  uint8_t g = (uint8_t)(255 + (cg - 255) * t);
  uint8_t b = (uint8_t)(255 + (cb - 255) * t);
  for (int i = 0; i < NEO_COUNT; i++) ring.setPixelColor(i, r, g, b);
}

// --- Pick a new random wander target for searching mode ---
// Alternates left/right each call so the eye sweeps back and forth naturally.
void pickSadSearchTarget() {
  targetTilt = random(SAD_TILT_MIN, SAD_TILT_MAX);

  if (panDirectionRight) {
    targetPan = random(90, SAD_PAN_MAX);
  } else {
    targetPan = random(SAD_PAN_MIN, 90);
  }
  panDirectionRight  = !panDirectionRight;
  searchMoveInterval = random(SEARCH_MOVE_MIN, SEARCH_MOVE_MAX);
  lastSearchMove     = millis();
}

// --- Pick a different colour index ---
int pickDifferentColour(int current) {
  int next = random(NUM_EYE_COLOURS);
  while (next == current) {
    next = random(NUM_EYE_COLOURS);
  }
  return next;
}

/* --- NeoPixel: sad searching ---
 Blink sweeps from top+bottom simultaneously toward the sides (like a real eyelid).
 blinkDist = distance from nearest pole (top=pixel 0, bottom=pixel NEO_COUNT/2).
 Max blinkDist = NEO_COUNT/4 (the side pixels, 4 and 12 on a 16-pixel ring).
*/
void updateSadSearching() {
  unsigned long now = millis();
  int halfRing = NEO_COUNT / 4;   // max blink distance = quarter-ring

  // Helper: distance from nearest vertical pole (top or bottom)
  auto blinkDist = [](int i) -> int {
    int dt = min(i, NEO_COUNT - i);          // distance from top (pixel 0)
    return min(dt, NEO_COUNT / 2 - dt);      // min of that and distance from bottom
  };

  if (sadBlinkPhase == 0) {
    // Fade in then hold at full brightness
    if (!sadBlinkHolding) {
      sadBrightness += SAD_FADE_SPEED;
      if (sadBrightness >= SAD_BRIGHTNESS_MAX) {
        sadBrightness   = SAD_BRIGHTNESS_MAX;
        sadBlinkHolding = true;
        sadBlinkTimer   = now;
      }
    } else if (now - sadBlinkTimer >= (unsigned long)BLINK_HOLD_MS) {
      // Hold time elapsed — start sweep off
      sadBlinkPhase = 1;
      sadBlinkStep  = 0;
      sadBlinkTimer = now;
    }
    uint8_t r = (uint8_t)(EYE_COLOURS[sadColourIndex][0] * sadBrightness);
    uint8_t g = (uint8_t)(EYE_COLOURS[sadColourIndex][1] * sadBrightness);
    uint8_t b = (uint8_t)(EYE_COLOURS[sadColourIndex][2] * sadBrightness);
    for (int i = 0; i < NEO_COUNT; i++) ring.setPixelColor(i, r, g, b);

  } else if (sadBlinkPhase == 1) {
    // Sweep off: top+bottom pixels close first, sides (pixels 4 & 12) close last
    if (now - sadBlinkTimer >= (unsigned long)BLINK_STEP_MS) {
      sadBlinkTimer = now;
      sadBlinkStep++;
    }
    uint8_t r1 = (uint8_t)(EYE_COLOURS[sadColourIndex][0] * SAD_BRIGHTNESS_MAX);
    uint8_t g1 = (uint8_t)(EYE_COLOURS[sadColourIndex][1] * SAD_BRIGHTNESS_MAX);
    uint8_t b1 = (uint8_t)(EYE_COLOURS[sadColourIndex][2] * SAD_BRIGHTNESS_MAX);
    for (int i = 0; i < NEO_COUNT; i++) {
      if (blinkDist(i) < sadBlinkStep) {
        ring.setPixelColor(i, 0, 0, 0);
      } else {
        ring.setPixelColor(i, r1, g1, b1);
      }
    }
    if (sadBlinkStep > halfRing) {
      // All pixels off — swap to next colour and begin sweep on
      sadColourIndex     = sadNextColourIndex;
      sadNextColourIndex = pickDifferentColour(sadColourIndex);
      sadBlinkPhase      = 2;
      sadBlinkStep       = halfRing;
      sadBlinkTimer      = now;
    }

  } else if (sadBlinkPhase == 2) {
    // Sweep on: sides open first, top+bottom open last
    if (now - sadBlinkTimer >= (unsigned long)BLINK_STEP_MS) {
      sadBlinkTimer = now;
      if (sadBlinkStep > 0) sadBlinkStep--;
    }
    uint8_t r2 = (uint8_t)(EYE_COLOURS[sadColourIndex][0] * SAD_BRIGHTNESS_MAX);
    uint8_t g2 = (uint8_t)(EYE_COLOURS[sadColourIndex][1] * SAD_BRIGHTNESS_MAX);
    uint8_t b2 = (uint8_t)(EYE_COLOURS[sadColourIndex][2] * SAD_BRIGHTNESS_MAX);
    for (int i = 0; i < NEO_COUNT; i++) {
      if (blinkDist(i) >= sadBlinkStep) {
        ring.setPixelColor(i, r2, g2, b2);
      } else {
        ring.setPixelColor(i, 0, 0, 0);
      }
    }
    if (sadBlinkStep <= 0) {
      // Fully open — return to hold phase
      sadBlinkPhase   = 0;
      sadBrightness   = SAD_BRIGHTNESS_MAX;
      sadBlinkHolding = true;
      sadBlinkTimer   = now;
    }
  }
}

// --- NeoPixel: tracking — blue/purple pulse with occasional scan ---
void updateTracking() {
  unsigned long now = millis();

  // Advance pulse
  trackBrightness += TRACK_PULSE_SPEED * trackBrightnessDir;
  if (trackBrightness >= TRACK_PULSE_MAX) {
    trackBrightness    = TRACK_PULSE_MAX;
    trackBrightnessDir = -1.0;
  } else if (trackBrightness <= TRACK_PULSE_MIN) {
    trackBrightness    = TRACK_PULSE_MIN;
    trackBrightnessDir = 1.0;
  }

  // Trigger scan
  if (!scanActive && now >= nextScanAt) {
    scanActive   = true;
    scanStep     = 0;
    lastScanStep = now;
  }

  // Advance scan step
  if (scanActive && now - lastScanStep >= (unsigned long)SCAN_STEP_MS) {
    lastScanStep = now;
    scanStep++;
    if (scanStep > NEO_COUNT / 2) {
      scanActive = false;
      nextScanAt = now + random(SCAN_INTERVAL_MIN, SCAN_INTERVAL_MAX);
    }
  }

  // Render pixels
  uint32_t baseColor = hsvToRgb(TRACK_HUE, 0.85, trackBrightness);
  for (int i = 0; i < NEO_COUNT; i++) {
    int dist = min(i, NEO_COUNT - i);   // distance from pixel 0 (top)
    if (scanActive && dist == scanStep) {
      ring.setPixelColor(i, 0, 150, 255);   // bright blue scan line
    } else {
      ring.setPixelColor(i, baseColor);
    }
  }
}

// --- NeoPixel: startled — white flash fading to tracking colour ---
// Phase 1 (first 15% of STARTLED_DURATION): ramp from black to full white.
// Phase 2 (remaining 85%): crossfade from white to the tracking pulse colour.
void updateStartled(unsigned long now) {
  float progress = (float)(now - startledStart) / (float)STARTLED_DURATION;

  if (progress >= 1.0) {
    trackBrightness = TRACK_PULSE_MIN;
    return;
  }

  uint8_t r, g, b;

  if (progress < 0.15) {
    uint8_t v = (uint8_t)(255 * (progress / 0.15));
    r = g = b = v;
  } else {
    float t = (progress - 0.15) / 0.85;
    uint32_t trackColor = hsvToRgb(TRACK_HUE, 0.85, TRACK_PULSE_MIN);
    uint8_t tr = (trackColor >> 16) & 0xFF;
    uint8_t tg = (trackColor >> 8)  & 0xFF;
    uint8_t tb =  trackColor        & 0xFF;

    r = (uint8_t)(255 + (tr - 255) * t);
    g = (uint8_t)(255 + (tg - 255) * t);
    b = (uint8_t)(255 + (tb - 255) * t);
  }

  for (int i = 0; i < NEO_COUNT; i++) {
    ring.setPixelColor(i, r, g, b);
  }
}

// --- Convert HSV (hue 0-1, saturation 0-1, value 0-1) to a NeoPixel uint32_t colour ---
uint32_t hsvToRgb(float h, float s, float v) {
  float r, g, b;
  int i   = (int)(h * 6);
  float f = h * 6 - i;
  float p = v * (1 - s);
  float q = v * (1 - f * s);
  float t = v * (1 - (1 - f) * s);

  switch (i % 6) {
    case 0: r = v; g = t; b = p; break;
    case 1: r = q; g = v; b = p; break;
    case 2: r = p; g = v; b = t; break;
    case 3: r = p; g = q; b = v; break;
    case 4: r = t; g = p; b = v; break;
    case 5: r = v; g = p; b = q; break;
    default: r = g = b = 0;
  }

  return ring.Color(
    (uint8_t)(r * 255),
    (uint8_t)(g * 255),
    (uint8_t)(b * 255)
  );
}
