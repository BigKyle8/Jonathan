    Serial.print("sad_tilt_min=");    Serial.println(SAD_TILT_MIN);
    Serial.print("sad_tilt_max=");    Serial.println(SAD_TILT_MAX);
    Serial.print("sad_pan_min=");     Serial.println(SAD_PAN_MIN);
    Serial.print("sad_pan_max=");     Serial.println(SAD_PAN_MAX);
    Serial.println("--- Blink & Scan ---");
    Serial.print("blink_step_ms=");   Serial.println(BLINK_STEP_MS);
    Serial.print("blink_hold_ms=");   Serial.println(BLINK_HOLD_MS);
    Serial.print("search_dim_secs="); Serial.println(SEARCH_DIM_SECS);
    Serial.print("scan_step_ms=");    Serial.println(SCAN_STEP_MS);
    Serial.print("scan_min_ms=");     Serial.println(SCAN_INTERVAL_MIN);
    Serial.print("scan_max_ms=");     Serial.println(SCAN_INTERVAL_MAX);
    return;
  }

  // --- Simple servo commands ---
  if (cmd == "home" || cmd == "HOME") {
    goHome();
    return;
  }
  if (cmd == "c" || cmd == "C") {
    servoTilt.write(90); servoPan.write(90); servoHome.write(90);
    currentPan = currentTilt = 90.0;
    Serial.println("All servos centred at 90°");
    return;
  }
  if (cmd == "a" || cmd == "A") {
    servoTilt.write(0); servoPan.write(0); servoHome.write(0);
    currentPan = currentTilt = 0.0;
    Serial.println("All servos → 0°");
