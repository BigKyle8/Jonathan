  }
  if (cmd == "b" || cmd == "B") {
    servoTilt.write(180); servoPan.write(180); servoHome.write(180);
    currentPan = currentTilt = 180.0;
    Serial.println("All servos → 180°");
    return;
  }

  // --- key=value commands ---
  int eqIdx = cmd.indexOf('=');
  if (eqIdx > 0) {
    String key = cmd.substring(0, eqIdx);
    String val = cmd.substring(eqIdx + 1);
    key.toLowerCase();
